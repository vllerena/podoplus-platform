NODE_ENV=development
API_PORT=3000
API_HOST=localhost
JWT_SECRET=dev_secret_key_change_in_prod
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod
JWT_REFRESH_EXPIRATION=7d
TIMEZONE=America/Lima

DATABASE_URL=postgresql://podoplus:podoplus@localhost:5432/podoplus_db

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=dev_webhook_token

# ── Email ──────────────────────────────────────────────────────────────────────
# Proveedor: "smtp" (genérico) | "mailtrap" (sandbox de pruebas)
MAIL_PROVIDER=mailtrap
MAIL_FROM=no-reply@podoplus.pe

# Mailtrap Sandbox — credenciales en https://mailtrap.io → Email Testing → Inboxes → SMTP Settings
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_pass

# SMTP genérico (solo si MAIL_PROVIDER=smtp)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_TLS=false
EMAIL_LOG_PATH=/app/logs/email.jsonl