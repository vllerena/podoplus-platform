{
  "name": "@podoplus/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch & sleep 2 && node --watch dist/main.js",
    "build": "tsc",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate --schema=../../apps/api/prisma/schema.prisma",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ]
  },
  "prisma": {
    "schema": "../../apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "bullmq": "^5.6.0",
    "@prisma/client": "^5.7.1",
    "redis": "^4.6.12",
    "dotenv": "^16.3.1",
    "@podoplus/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.4",
    "jest": "^29.7.0",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.4",
    "typescript": "^6.0.0"
  }
}
