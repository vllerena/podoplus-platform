datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// SEGURIDAD Y AUTENTICACIÓN
// ============================================================================

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relaciones
  roles                    UserRole[]
  branches                 UserBranch[]
  appointmentsCreated      Appointment[] @relation("CreatedByUser")
  appointmentsCanceled     Appointment[] @relation("CanceledByUser")
  blockCreated             BranchBlock[] @relation("BlockCreatedBy")
  cashRegistersOpened      CashRegister[] @relation("OpenedBy")
  cashRegistersClosed      CashRegister[] @relation("ClosedBy")
  cashMovements            CashMovement[]
  salesCreated             Sale[] @relation("SaleCreatedBy")
  inventoryMovements       InventoryMovement[]
  subscriptionsCanceled    CustomerSubscription[] @relation("CanceledSub")
  subscriptionsCreated     CustomerSubscription[] @relation("CreatedSub")
  subscriptionConsumptions SubscriptionConsumption[]
  auditLogs                AuditLog[]
  scheduleExceptions BranchScheduleException[] @relation("ScheduleExceptionCreatedBy")

  @@index([email])
  @@index([isActive])
  @@index([createdAt])
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users       UserRole[]

  @@index([code])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([code])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================================================
// SEDES/BRANCHES
// ============================================================================

model Branch {
  id              String   @id @default(cuid())
  code            String?  @unique
  name            String
  address         String?
  district        String?
  city            String?
  phone           String?
  isActive        Boolean  @default(true)
  defaultCapacity Int      @default(6)
  timezone        String   @default("America/Lima")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relaciones
  users            UserBranch[]
  hours            BranchHour[]
  blocks           BranchBlock[]
  capacityRules    BranchCapacityRule[]
  appointments     Appointment[]
  cashRegisters    CashRegister[]
  sales            Sale[]
  inventoryStocks  InventoryStock[]
  inventoryMoves   InventoryMovement[]
  whatsappLogs     WhatsappMessageLog[]
  subscriptions    CustomerSubscription[]
  servicePrices       ServiceBranchPrice[]
  scheduleExceptions  BranchScheduleException[] @relation("BranchScheduleExceptions")

  @@index([code])
  @@index([isActive])
  @@index([createdAt])
}

model UserBranch {
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ============================================================================
// HORARIOS Y BLOQUES DE TIEMPO
// ============================================================================

model BranchHour {
  id        String  @id @default(cuid())
  branchId  String
  weekday   Int     // 0-6 (Domingo a Sábado)
  startTime String  // HH:mm
  endTime   String  // HH:mm
  isActive  Boolean @default(true)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, weekday, startTime, endTime])
  @@index([branchId])
  @@index([weekday])
}

model BranchBlock {
  id          String   @id @default(cuid())
  branchId    String
  type        String   // LUNCH, HOLIDAY, MAINTENANCE, EVENT, CUSTOM
  title       String
  startAt     DateTime
  endAt       DateTime
  isRecurring Boolean  @default(false)
  weekday     Int?     // 0-6 si es recurrente
  startTime   String?  // HH:mm si es recurrente
  endTime     String?  // HH:mm si es recurrente
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("BlockCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([startAt])
  @@index([endAt])
}

model BranchCapacityRule {
  id        String   @id @default(cuid())
  branchId  String
  scopeType String   // DATE, WEEKDAY_RANGE
  date      DateTime? // para scope DATE
  weekday   Int?     // para scope WEEKDAY_RANGE
  startTime String?  // HH:mm
  endTime   String?  // HH:mm
  capacity  Int
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([date])
  @@index([scopeType])
}

model BranchScheduleException {
  id            String   @id @default(cuid())
  branchId      String
  date          DateTime
  startTime     String   // HH:mm
  endTime       String   // HH:mm
  reason        String?  // Ej: "Evento especial", "Cambio de turno"
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch    Branch @relation("BranchScheduleExceptions", fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ScheduleExceptionCreatedBy", fields: [createdById], references: [id])

  @@unique([branchId, date])
  @@index([branchId])
  @@index([date])
}

// ============================================================================
// CLIENTES/PACIENTES
// ============================================================================

model Customer {
  id             String   @id @default(cuid())
  documentType   String?
  documentNumber String?  @unique
  firstName      String
  lastName       String
  phone          String?
  email          String?
  birthDate      DateTime?
  gender         String?
  notes          String?
  whatsappOptIn  Boolean  @default(false)
  familyHeadId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  familyMembers  Customer[] @relation("FamilyRelation")
  familyHead     Customer?  @relation("FamilyRelation", fields: [familyHeadId], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  subscriptions  CustomerSubscription[]
  sales          Sale[]
  whatsappLogs   WhatsappMessageLog[]

  @@index([firstName])
  @@index([lastName])
  @@index([documentNumber])
  @@index([phone])
  @@index([email])
  @@index([familyHeadId])
  @@index([createdAt])
}

// ============================================================================
// SERVICIOS
// ============================================================================

model Service {
  id               String   @id @default(cuid())
  name             String
  description      String?
  durationMinutes  Int
  bufferMinutes    Int      @default(0)
  basePrice        Decimal  @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  allowSelfService Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  appointments Appointment[]
  branchPrices ServiceBranchPrice[]
  saleItems    SaleItem[]

  @@index([isActive])
  @@index([createdAt])
}

model ServiceBranchPrice {
  serviceId String
  branchId  String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([serviceId, branchId])
  @@index([serviceId])
  @@index([branchId])
}

// ============================================================================
// CITAS (CORE DEL SISTEMA)
// ============================================================================

model Appointment {
  id              String   @id @default(cuid())
  branchId        String
  customerId      String
  serviceId       String
  startAt         DateTime
  endAt           DateTime
  status          String   // PENDING, CONFIRMED, CHECKED_IN, IN_SERVICE, COMPLETED, RESCHEDULED, CANCELED, NO_SHOW
  source          String   // RECEPTION, PORTAL, STAFF, SYSTEM
  notes           String?
  cancelReason    String?
  canceledByType  String?  // USER, CUSTOMER, SYSTEM
  canceledById    String?
  canceledAt      DateTime?
  rescheduledFromId String?
  rescheduledToId String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  branch          Branch   @relation(fields: [branchId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])
  service         Service  @relation(fields: [serviceId], references: [id])
  canceledBy      User?    @relation("CanceledByUser", fields: [canceledById], references: [id])
  createdBy       User?    @relation("CreatedByUser", fields: [createdById], references: [id])
  statusHistory   AppointmentStatusHistory[]
  sale            Sale?
  subscription    CustomerSubscription?
  whatsappLogs    WhatsappMessageLog[]
  consumptions    SubscriptionConsumption[]

  @@index([branchId])
  @@index([customerId])
  @@index([serviceId])
  @@index([startAt])
  @@index([endAt])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([branchId, startAt])
}

model AppointmentStatusHistory {
  id            String   @id @default(cuid())
  appointmentId String
  fromStatus    String?
  toStatus      String
  changedByType String   // USER, CUSTOMER, SYSTEM
  changedById   String?
  reason        String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([toStatus])
  @@index([createdAt])
}

// ============================================================================
// CAJA/CASH REGISTER
// ============================================================================

model CashRegister {
  id                     String   @id @default(cuid())
  branchId               String
  openedById             String
  openedAt               DateTime @default(now())
  openingBalance         Decimal  @db.Decimal(12, 2)
  closedById             String?
  closedAt               DateTime?
  closingBalanceReported Decimal? @db.Decimal(12, 2)
  closingBalanceSystem   Decimal? @db.Decimal(12, 2)
  difference             Decimal? @db.Decimal(12, 2)
  status                 String   @default("OPEN") // OPEN, CLOSED
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relaciones
  branch    Branch          @relation(fields: [branchId], references: [id])
  openedBy  User            @relation("OpenedBy", fields: [openedById], references: [id])
  closedBy  User?           @relation("ClosedBy", fields: [closedById], references: [id])
  movements CashMovement[]
  sales     Sale[]

  @@index([branchId])
  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
}

model CashMovement {
  id             String   @id @default(cuid())
  cashRegisterId String
  type           String   // IN, OUT
  amount         Decimal  @db.Decimal(12, 2)
  reason         String
  createdById    String
  createdAt      DateTime @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([cashRegisterId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// VENTAS Y ARTÍCULOS
// ============================================================================

model Sale {
  id              String   @id @default(cuid())
  branchId        String
  customerId      String?
  appointmentId   String?  @unique
  cashRegisterId  String?
  totalAmount     Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  paymentMethod   String   // CASH, CARD, YAPE, PLIN, TRANSFER, MIXED
  status          String   @default("PAID") // PAID, REFUNDED, VOIDED
  voidReason      String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  branch       Branch       @relation(fields: [branchId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  cashRegister CashRegister? @relation(fields: [cashRegisterId], references: [id])
  createdBy    User         @relation("SaleCreatedBy", fields: [createdById], references: [id])
  items        SaleItem[]

  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  itemType  String   // PRODUCT, SERVICE, PLAN
  productId String?
  serviceId String?
  planId    String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  plan    Plan?    @relation(fields: [planId], references: [id])

  @@index([saleId])
  @@index([itemType])
}

// ============================================================================
// PRODUCTOS E INVENTARIO
// ============================================================================

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  unitType    String   // unit, box, etc
  costPrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  stocks    InventoryStock[]
  movements InventoryMovement[]
  saleItems SaleItem[]

  @@index([sku])
  @@index([isActive])
}

model InventoryStock {
  branchId  String
  productId String
  quantity  Int
  updatedAt DateTime @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([branchId, productId])
  @@index([branchId])
  @@index([productId])
}

model InventoryMovement {
  id            String   @id @default(cuid())
  branchId      String
  productId     String
  type          String   // PURCHASE_IN, SALE_OUT, ADJUSTMENT, TRANSFER_OUT, TRANSFER_IN, RETURN_IN
  quantity      Int
  referenceType String?  // SALE, TRANSFER, MANUAL, PURCHASE
  referenceId   String?
  reason        String?
  createdById   String
  createdAt     DateTime @default(now())

  branch    Branch  @relation(fields: [branchId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([branchId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// PLANES Y SUSCRIPCIONES
// ============================================================================

model Plan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  durationDays     Int
  includedSessions Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  subscriptions CustomerSubscription[]
  saleItems     SaleItem[]

  @@index([isActive])
}

model CustomerSubscription {
  id                String   @id @default(cuid())
  customerId        String
  planId            String
  branchId          String
  appointmentId     String?  @unique
  status            String   // ACTIVE, PAUSED, CANCELED, EXPIRED
  startDate         DateTime
  endDate           DateTime
  remainingSessions Int
  cancelReason      String?
  canceledById      String?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  customer     Customer                 @relation(fields: [customerId], references: [id])
  plan         Plan                     @relation(fields: [planId], references: [id])
  branch       Branch                   @relation(fields: [branchId], references: [id])
  appointment  Appointment?             @relation(fields: [appointmentId], references: [id])
  canceledBy   User?                    @relation("CanceledSub", fields: [canceledById], references: [id])
  createdBy    User                     @relation("CreatedSub", fields: [createdById], references: [id])
  consumptions SubscriptionConsumption[]

  @@index([customerId])
  @@index([planId])
  @@index([branchId])
  @@index([status])
  @@index([endDate])
}

model SubscriptionConsumption {
  id               String   @id @default(cuid())
  subscriptionId   String
  appointmentId    String?
  consumedSessions Int      @default(1)
  consumedAt       DateTime @default(now())
  createdById      String
  createdAt        DateTime @default(now())

  subscription CustomerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  appointment  Appointment?         @relation(fields: [appointmentId], references: [id])
  createdBy    User                 @relation(fields: [createdById], references: [id])

  @@index([subscriptionId])
  @@index([appointmentId])
  @@index([consumedAt])
}

// ============================================================================
// WHATSAPP
// ============================================================================

model WhatsappTemplate {
  id          String   @id @default(cuid())
  name        String
  templateKey String
  category    String
  language    String   @default("es")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs WhatsappMessageLog[]

  @@index([templateKey])
  @@index([isActive])
}

model WhatsappMessageLog {
  id                String   @id @default(cuid())
  branchId          String
  customerId        String?
  appointmentId     String?
  templateId        String?
  toPhone           String
  messageType       String   // TEMPLATE, TEXT
  payloadJson       Json
  status            String   @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
  providerMessageId String?
  errorMessage      String?
  scheduledFor      DateTime?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  branch      Branch            @relation(fields: [branchId], references: [id])
  customer    Customer?         @relation(fields: [customerId], references: [id])
  appointment Appointment?      @relation(fields: [appointmentId], references: [id])
  template    WhatsappTemplate? @relation(fields: [templateId], references: [id])

  @@index([branchId])
  @@index([customerId])
  @@index([appointmentId])
  @@index([status])
  @@index([toPhone])
  @@index([createdAt])
}

// ============================================================================
// AUDITORÍA
// ============================================================================

model AuditLog {
  id           String   @id @default(cuid())
  actorType    String   // USER, SYSTEM
  actorId      String?
  branchId     String?
  action       String
  entityType   String
  entityId     String
  reason       String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityId])
  @@index([action])
  @@index([entityType])
  @@index([actorType])
  @@index([createdAt])
  @@index([branchId])
}
