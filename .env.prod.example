# ─────────────────────────────────────────────────────────────────────────────
# Podoplus Platform — Variables de entorno de PRODUCCIÓN
# Copia este archivo como .env.prod y completa los valores
# NUNCA subas .env.prod al repositorio (está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── GENERAL ──────────────────────────────────────────────────────────────────
TIMEZONE=America/Lima

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000

# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
POSTGRES_USER=podoplus
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=podoplus_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Opcional: proteger Redis con contraseña en producción
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_ALEATORIO_LARGO
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=CAMBIAR_POR_REFRESH_SECRET_ALEATORIO_LARGO
JWT_REFRESH_EXPIRATION=7d

# ── WHATSAPP (opcional) ───────────────────────────────────────────────────────
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_TOKEN=
