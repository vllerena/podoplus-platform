# MailTrap SMTP settings
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your-mailtrap-username
MAIL_PASS=your-mailtrap-password
MAIL_FROM=no-reply@podoplus.pe
MAIL_SECURE=false
MAIL_TLS=false

# Notificaciones internas: registro JSON local mientras no hay canal externo configurado
NOTIFICATION_LOG_PATH=logs/notifications.jsonl

# Sincronización SUNAT simulada: log JSON local para facturas/boletas
SUNAT_SYNC_LOG_PATH=logs/sunat-sync.jsonl
